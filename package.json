{
  "name": "fast-value",
  "version": "1.0.0",
  "description": "高性能数据更新库 - 基于输入框value属性的零DOM操作方案",
  "main": "dist/fast-value.js",
  "module": "dist/fast-value.esm.js",
  "style": "dist/fast-value.css",
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:js && npm run build:css",
    "build:js": "rollup -c",
    "build:css": "postcss src/fast-value.css -o dist/fast-value.min.css",
    "dev": "rollup -c -w",
    "test": "jest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "performance",
    "data-binding",
    "real-time",
    "dashboard",
    "ui",
    "fast",
    "zero-dom",
    "input-value",
    "lightweight"
  ],
  "author": "FastValue Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/fast-value.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/fast-value/issues"
  },
  "homepage": "https://github.com/yourusername/fast-value#readme",
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.35",
    "postcss-cli": "^11.0.0",
    "rollup": "^4.12.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
